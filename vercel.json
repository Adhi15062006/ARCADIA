{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": ["dist/server-bundle.cjs"]
    }
  },
  "rewrites": [
    {
      "source": "/api/test-all",
      "destination": "/api/test-all.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/firebase-config.js",
      "destination": "/api/index.js"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/index.js"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/index.js"
    },
    {
      "source": "/auth/callback",
      "destination": "/api/index.js"
    },
    {
      "source": "/auth/callback/",
      "destination": "/api/index.js"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
