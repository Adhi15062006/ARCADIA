{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/test-all",
      "destination": "/api/test-all.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/firebase-config.js",
      "destination": "/api/index.ts"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/index.ts"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/index.ts"
    },
    {
      "source": "/auth/callback",
      "destination": "/api/index.ts"
    },
    {
      "source": "/auth/callback/",
      "destination": "/api/index.ts"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
