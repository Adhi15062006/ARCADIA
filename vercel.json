{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": ["data/**", "firebase-applet-config.json", "dist/server.cjs"]
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/firebase-config.js",
      "destination": "/api/index.js"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/index.js"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/index.js"
    },
    {
      "source": "/auth/callback",
      "destination": "/api/index.js"
    },
    {
      "source": "/auth/callback/",
      "destination": "/api/index.js"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
